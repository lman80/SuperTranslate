{
  "name": "supertranslate",
  "version": "0.1.0",
  "description": "Live speech-translation overlay for Mac & Windows (Korean / Chinese / English)",
  "main": "./out/main/index.js",
  "author": "Brimmer Industries",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "pack:win": "electron-vite build && electron-builder --win"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "audiotee": "^0.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
